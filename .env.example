# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
# For local MongoDB: mongodb://localhost:27017/water-cms
# For MongoDB Atlas: mongodb+srv://<username>:<password>@cluster.mongodb.net/water-cms
MONGO_URI=mongodb://localhost:27017/water-cms

# Security & Authentication (For future phases)
JWT_SECRET=your_jwt_secret_key_here_change_in_production
JWT_EXPIRES_IN=7d

# Production Frontend URL for CORS Whitelisting
FRONTEND_URL=https://msro.techbuilt.in
